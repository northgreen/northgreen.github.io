<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>
        <%= config.title %>
    </title>
    <script>!function(){var t;try{t=localStorage.getItem('aero-theme')}catch(e){}t&&document.documentElement.setAttribute('data-theme',t)}()</script>
    <%- css('css/style.css') %>
    <% if (theme.favicon.enable) { %>
        <% if (theme.favicon.icon) { %>
            <link rel="icon" href="<%= url_for(theme.favicon.icon) %>">
        <% } %>
    <% } %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.9.1/fonts/remixicon.css">
    <link rel="alternate" type="application/atom+xml" title="<%= config.title %> - Atom" href="<%= url_for('atom.xml') %>">
    <link rel="alternate" type="application/rss+xml" title="<%= config.title %> - RSS" href="<%= url_for('rss2.xml') %>">
    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="<%= page.type === 'post' ? 'article' : 'website' %>">
    <meta property="og:title" content="<%= page.title || config.title %>">
    <meta property="og:description" content="<%= (page.description || page.excerpt || config.description || '').substring(0, 150) %>">
    <meta property="og:url" content="<%= page.permalink || config.url + url_for(page.path) %>">
    <meta property="og:site_name" content="<%= config.title %>">
    <% if (page.type === 'post') { %>
    <meta property="og:image" content="<%= config.url %>/og-images/<%= encodeURIComponent(page.slug) %>.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <% } %>
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page.title || config.title %>">
    <meta name="twitter:description" content="<%= (page.description || page.excerpt || config.description || '').substring(0, 150) %>">
    <% if (page.type === 'post') { %>
    <meta name="twitter:image" content="<%= config.url %>/og-images/<%= encodeURIComponent(page.slug) %>.png">
    <% } %>
</head>

<body>
    <div class="container">
        <!-- header -->
        <%- partial('_partial/header') %>

        <div class="button mobile-menu-btn" id="mobile-menu-btn">
            <span class="menu-icon ri-menu-fill"></span>
        </div>

        <div class="main-layout">
            <aside id="sidebar">
                <%- partial('_partial/widget') %>
            </aside>
            <main id="pjax-container">
                <%- body %>
            </main>
            <div class="sidebar-mask" id="sidebar-mask"></div>
        </div>

        <!-- footer -->
        <%- partial('_partial/footer') %>
    </div>

    <script src="/js/responsive.js"></script>
    <script src="/js/nav-overflow.js"></script>
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/music.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/pjax/pjax.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            window.pjax = new Pjax({
                elements: 'a[href]:not([target]):not([data-no-pjax])',
                selectors: [
                    'title',
                    '#pjax-container',
                    '#pjax-header'
                ]
            })
        })
    </script>
    <%
      // 自动检测是否包含数学公式（$...$ 或 $$...$$）
      // 跳过 ``` 代码块内的内容
      var hasMath = false;
      if (theme.math.enable && page._content) {
        // 使用原始 Markdown 内容（page._content），避免 $ 被 HTML 转义干扰
        var content = page._content;
        // 移除代码块
        var withoutCode = content.replace(/```[\s\S]*?```/g, '');
        hasMath = /\$\$[^$]+\$\$/.test(withoutCode) || /\$[^$\n]+\$/.test(withoutCode);
      }
    %>
    <% if (theme.math.enable && (page.mathjax || hasMath)) { %>
        <script>
            window.MathJax = {
                tex: {
                    inlineMath: [['$', '$'], ["\\(", "\\)"]],
                    displayMath: [ ['$$','$$'], ["\\[","\\]"] ],
                    processEscapes: true,
                    packages: {'[+]': ['noerrors']}
                },
                options: {
                    skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
                    ignoreHtmlClass: 'tex2jax_ignore',
                    processHtmlClass: 'tex2jax_process'
                },
                loader: {
                    load: ['[tex]/noerrors']
                },
                startup: {
                    pageReady: function() {
                        return MathJax.typesetPromise();
                    }
                }
            };
        </script>
        <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" id="MathJax-script"></script>
    <% } %>
        <script>
            // PJAX 导航后重新排版 MathJax 公式（始终注册，即使当前页无公式）
            document.addEventListener('pjax:success', function() {
                if (window.MathJax && typeof MathJax.typesetPromise === 'function') {
                    MathJax.typesetPromise();
                }
            });
        </script>
    <% if (theme.graph && theme.graph.enable) { %>
    <script src="https://cdn.jsdelivr.net/npm/pixi.js@8.18.1/dist/pixi.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js"></script>
    <script src="/js/graph.js"></script>
    <% } %>
    <% if (theme.mermaid && theme.mermaid.enable) { %>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11.4.0/dist/mermaid.min.js"></script>
    <script src="/js/mermaid-init.js"></script>
    <% } %>
    <% if (page.type === 'folders') { %>
    <script src="/js/folder-tree.js"></script>
    <% } %>
    <% if (theme.search && theme.search.enable) { %>
    <script src="/js/vendor/flexsearch.min.js"></script>
    <script src="/js/vendor/dompurify.min.js"></script>
    <script src="/js/search.js"></script>
    <script src="/js/search-preview.js"></script>
    <% } %>
</body>

</html>
